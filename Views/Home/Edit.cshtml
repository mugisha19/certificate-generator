@model CertificateOfAttendance
@{
    ViewData["Title"] = "Edit certificate";
}

<div class="page">
    <div class="page__head">
        <div>
            <h1 class="page__title">Edit certificate</h1>
            <p class="page__sub">@Model.StudentName · <span class="mono">@Model.StudentID</span></p>
        </div>
        <a asp-action="Details" asp-route-studentId="@Model.StudentID" class="btn btn--ghost">
            <svg class="i" viewBox="0 0 24 24" aria-hidden="true"><path d="M15 6 9 12l6 6M9 12h10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span>Back</span>
        </a>
    </div>

    <div class="panel">
        <form asp-action="Edit" asp-route-studentId="@Model.OriginalStudentID" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="OriginalStudentID" />
            <div asp-validation-summary="ModelOnly" class="vsummary"></div>

            @await Html.PartialAsync("_CertificateForm", Model)

            <div class="form__actions">
                <button type="submit" class="btn btn--accent btn--lg">
                    <svg class="i" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 4h11l3 3v13H5V4ZM8 4v5h8V4M9 20v-6h6v6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
                    <span>Save changes</span>
                </button>
                <a asp-action="Details" asp-route-studentId="@Model.StudentID" class="btn btn--ghost btn--lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
